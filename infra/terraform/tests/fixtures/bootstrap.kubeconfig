apiVersion: v1
kind: Config
clusters:
  - name: bootstrap-test
    cluster:
      server: https://127.0.0.1:65535
      insecure-skip-tls-verify: true
contexts:
  - name: bootstrap-test
    context:
      cluster: bootstrap-test
      user: bootstrap-test
current-context: bootstrap-test
users:
  - name: bootstrap-test
    user:
      token: bootstrap-test
