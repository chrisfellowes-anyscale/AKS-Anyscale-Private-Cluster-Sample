# Copy this file to .env and fill in environment-specific values.
#
# Prefix conventions:
# - ARM_* configures AzureRM provider authentication/environment context.
# - TF_VAR_* configures Terraform input variables. scripts/setup.sh stages these
#   values into infra/terraform/terraform.auto.tfvars.json before plan/apply.

###############################################################################
# AzureRM provider authentication/context
###############################################################################
ARM_SUBSCRIPTION_ID="00000000-0000-0000-0000-000000000000"
ARM_TENANT_ID="00000000-0000-0000-0000-000000000000"
ARM_USE_CLI="true"

# Optional non-interactive auth patterns. Do not commit secrets.
# ARM_CLIENT_ID="00000000-0000-0000-0000-000000000000"
# ARM_CLIENT_SECRET=""
# ARM_USE_OIDC="true"
# ARM_USE_MSI="true"

###############################################################################
# Anyscale CLI / post-configuration
###############################################################################
# scripts/setup.sh auto-derives ANYSCALE_CLOUD_NAME as
# <project>-<environment>-<region_short> and caches it into .env.
# scripts/setup.sh also auto-discovers ANYSCALE_CLOUD_DEPLOYMENT_ID from the
# live Azure Anyscale cloud resource after the platform deployment exists.
# This repo targets the Azure-hosted Anyscale control plane.
# The only Anyscale value you normally need to supply manually is
# ANYSCALE_CLI_TOKEN, but setting ANYSCALE_HOST explicitly keeps direct CLI use
# aligned with the Azure deployment too.
ANYSCALE_HOST="https://console.azure.anyscale.com"
ANYSCALE_CLOUD_NAME=""
ANYSCALE_CLOUD_DEPLOYMENT_ID=""
ANYSCALE_CLI_TOKEN=""

###############################################################################
# Terraform input variables
###############################################################################
TF_VAR_azure_subscription_id="00000000-0000-0000-0000-000000000000"
TF_VAR_azure_tenant_id="00000000-0000-0000-0000-000000000000"
TF_VAR_project="myproject"
TF_VAR_environment="dev"
TF_VAR_azure_location="westus3"
TF_VAR_region_short="wus3"

TF_VAR_vnet_address_space='["10.50.0.0/16"]'
TF_VAR_subnet_cidrs='{"firewall":"10.50.0.0/26","firewall_management":"10.50.0.64/26","bastion":"10.50.0.128/26","aks_apiserver":"10.50.1.0/28","dns_resolver_in":"10.50.1.16/28","dns_resolver_out":"10.50.1.32/28","private_endpoints":"10.50.2.0/24","aks_nodes":"10.50.4.0/22"}'

# Optional enterprise DNS conditional forwarding rules for Azure DNS Private Resolver.
# Example:
# TF_VAR_dns_forwarding_rules='{"corp-contoso":{"domain_name":"corp.contoso.com.","target_dns_servers":[{"ip_address":"10.10.10.10","port":53}]}}'
TF_VAR_dns_forwarding_rules='{}'

# Starter Anyscale FQDN allow-list. Verify against:
# https://docs.anyscale.com/networking/overview#important-domains
TF_VAR_anyscale_fqdns='["console.anyscale.com","console.azure.anyscale.com","api.azure.anyscale.com","*.az1.westus2.admin.azure.anyscale.com","anyscaleazwestus2prod.blob.core.windows.net","anyscaleazwestus2prod.dfs.core.windows.net","api.anyscale.com","anyscale-public.s3.us-west-2.amazonaws.com","anyscale.com"]'

# Required for AKS Workload Identity token exchange and Azure SDK/CLI auth flows
# from private pods when egress is forced through Azure Firewall.
TF_VAR_azure_identity_fqdns='["login.microsoftonline.com","*.login.microsoftonline.com","sts.windows.net","management.azure.com"]'

# Azure Monitor / Log Analytics / Azure Monitor Agent endpoints. AMPLS private
# endpoints are also created; this allow-list keeps public fallback intentional
# for Microsoft-documented Monitor agent/config/query endpoints.
TF_VAR_azure_monitor_fqdns='["global.handler.control.monitor.azure.com","*.handler.control.monitor.azure.com","global.prod.microsoftmetrics.com","*.monitoring.azure.com","*.ods.opinsights.azure.com","*.oms.opinsights.azure.com","*.agentsvc.azure-automation.net","*.ingest.monitor.azure.com","*.monitor.azure.com"]'

TF_VAR_container_registry_fqdns='["mcr.microsoft.com","*.data.mcr.microsoft.com","ghcr.io","*.ghcr.io","pkg-containers.githubusercontent.com","*.docker.io","registry-1.docker.io","auth.docker.io","production.cloudflare.docker.com","quay.io","*.quay.io","registry.k8s.io","k8s.gcr.io","gcr.io","*.gcr.io","*.pkg.dev","us-docker.pkg.dev","europe-docker.pkg.dev","asia-docker.pkg.dev","nvcr.io","*.nvcr.io","authn.nvidia.com","arcmktplaceprod.azurecr.io","*.data.azurecr.io","prod-registry-k8s-io-us-west-1.s3.dualstack.us-west-1.amazonaws.com"]'

TF_VAR_availability_zones='["1","2","3"]'
TF_VAR_aks_sku_tier="Standard"
TF_VAR_system_node_pool_min_count="3"
TF_VAR_system_node_pool_max_count="6"
TF_VAR_system_vm_size="Standard_D2s_v5"
TF_VAR_cpu_vm_size="Standard_D16s_v5"
# Keep one GPU node warm by default so workspace and smoke-test flows do not
# depend on scale-from-zero before the first GPU workload can start.
TF_VAR_gpu_pool_configs='{"T4":{"name":"gput4","vm_size":"Standard_NC16as_T4_v3","product_name":"NVIDIA-T4","gpu_count":"1","min_count":1,"max_count":2,"availability_zones":[]}}'

# Pin an exact AKS patch version for reproducible node bootstrap behavior.
# Set to 'null' only when intentionally accepting the regional default.
TF_VAR_kubernetes_version='"1.34.6"'
TF_VAR_service_cidr="10.100.0.0/16"
TF_VAR_dns_service_ip="10.100.0.10"
TF_VAR_anyscale_operator_namespace="anyscale-operator"
TF_VAR_anyscale_operator_serviceaccount="anyscale-operator"

# Anyscale operator identity modes:
# - create: Terraform creates the UAMI and container-scoped storage RBAC.
# - existing-managed-rbac: supply existing UAMI IDs; Terraform creates storage RBAC.
# - existing-external-rbac: supply existing UAMI IDs; RBAC is managed outside Terraform.
TF_VAR_anyscale_operator_identity='{"mode":"create"}'

TF_VAR_storage_cors_rule='{"allowed_headers":["*"],"allowed_methods":["GET","POST","PUT","HEAD","DELETE"],"allowed_origins":["https://*.anyscale.com"],"expose_headers":["Accept-Ranges","Content-Range","Content-Length"],"max_age_in_seconds":0}'

TF_VAR_storage_replication_type="ZRS"
TF_VAR_acr_zone_redundancy_enabled="true"

TF_VAR_log_analytics_retention_days="30"
TF_VAR_log_analytics_internet_ingestion_enabled="false"
TF_VAR_log_analytics_internet_query_enabled="true"
TF_VAR_ampls_enabled="true"
TF_VAR_ampls_ingestion_access_mode="PrivateOnly"
TF_VAR_ampls_query_access_mode="Open"
TF_VAR_container_insights_v2_enabled="true"
TF_VAR_container_insights_streams='["Microsoft-ContainerLogV2","Microsoft-KubeEvents","Microsoft-KubePodInventory"]'
TF_VAR_container_insights_data_collection_interval="1m"
TF_VAR_container_insights_namespace_filtering_mode="Off"
TF_VAR_container_insights_namespaces='[]'
TF_VAR_terraform_managed_diagnostic_settings_enabled="true"
TF_VAR_tags='{"Project":"myproject","Environment":"dev","ManagedBy":"terraform","Owner":"change-me"}'
